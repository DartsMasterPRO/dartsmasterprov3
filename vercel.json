{
  "buildCommand": "",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(manifest\\.json|sw\\.js|favicon\\.ico|icon-.*\\.png)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
